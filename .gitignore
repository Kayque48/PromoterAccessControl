# ========================================
# .gitignore - Promoter Access Control
# ========================================

# ------------------------------
# .NET / C# build artifacts
# ------------------------------
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
AnyCPU/

# Arquivos gerados em build/publicação
publish/
PublishProfiles/
artifacts/

# Arquivos de pacote / restore
*.nupkg
*.snupkg
*.nuspec
.nuget/
packages/

# ------------------------------
# User / IDE / editor
# ------------------------------
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.csproj.user
*.rsuser
*.sln.DotSettings.user
*.userprefs

# Arquivos temporários de editor/sistema
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# ------------------------------
# Logs / diagnostics
# ------------------------------
*.log
logs/
*.stackdump

# ------------------------------
# Environment / local config
# ------------------------------
.env
.env.*
!.env.example

# Config local de desenvolvimento
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json

# ------------------------------
# Databases / local data
# ------------------------------
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Se quiser preservar scripts SQL, eles NÃO entram aqui.
# Ex.: database/*.sql continua versionado.

# ------------------------------
# Frontend / generic build outputs
# ------------------------------
dist/
build/
coverage/
.nyc_output/
node_modules/

# ------------------------------
# Testing / misc
# ------------------------------
TestResults/
*.trx
*.coverage
*.coveragexml

# ------------------------------
# OS / cache leftovers
# ------------------------------
.fake/