# ========================================
# .gitignore - Promoter Access Control
# ========================================

# ------------------------------
# .NET / C# build artifacts
# ------------------------------
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
AnyCPU/
artifacts/
publish/
PublishProfiles/

# Pacotes / restore
*.nupkg
*.snupkg
*.nuspec
.nuget/
packages/

# ------------------------------
# Visual Studio / VS Code / IDEs
# ------------------------------
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.csproj.user
*.rsuser
*.userprefs

# Cache / arquivos de editor
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# ------------------------------
# Logs / diagnósticos
# ------------------------------
*.log
logs/
*.stackdump

# ------------------------------
# Ambiente / configs locais
# ------------------------------
.env
.env.*
!.env.example

appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json

# ------------------------------
# Bancos locais / temporários
# ------------------------------
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Cache específico
*.lscache
*.cache

# ------------------------------
# Frontend / artefatos genéricos
# ------------------------------
dist/
build/
coverage/
.nyc_output/
node_modules/

# ------------------------------
# Testes
# ------------------------------
TestResults/
*.trx
*.coverage
*.coveragexml